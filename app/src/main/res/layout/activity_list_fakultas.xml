<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:orientation="vertical"
    android:padding="16dp"

    android:background="@color/pipi_secondary">

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Peminjaman Ruangan"
        android:textSize="24sp"
        android:textStyle="bold"

        android:textColor="@color/pipi_dark"/>

    <!-- SUBTITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Pilih Fakultas"
        android:textSize="14sp"

        android:textColor="@color/gray"

        android:layout_marginTop="4dp"/>

    <!-- BANNER -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="180dp"

        android:layout_marginTop="20dp"

        app:cardCornerRadius="28dp"
        app:cardElevation="2dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- FOTO GEDUNG -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:src="@drawable/upn_building"

                android:scaleType="centerCrop"/>

            <!-- OVERLAY GELAP -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:background="#66000000"/>

            <!-- TEXT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:orientation="vertical"
                android:gravity="bottom"

                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:lineSpacingExtra="4dp"

                    android:text="Gunakan ruangan secara tertib dan\nbertanggung jawab"
                    android:textAlignment="center"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"

                    android:textStyle="bold" />

            </LinearLayout>

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- RECYCLERVIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFakultas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:layout_marginTop="20dp"/>

</LinearLayout>